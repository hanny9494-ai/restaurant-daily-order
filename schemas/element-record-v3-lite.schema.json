{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jify.local/schema/element-record-v3-lite.json",
  "title": "ElementRecordV3Lite",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "production", "allergens", "ingredients", "steps", "component_refs"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dish_code",
        "dish_name",
        "display_name",
        "aliases",
        "entity_kind",
        "business_type",
        "technique_family",
        "menu_cycle",
        "plating_image_url"
      ],
      "properties": {
        "dish_code": { "type": "string", "minLength": 1 },
        "dish_name": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "entity_kind": { "type": "string", "const": "ELEMENT" },
        "business_type": { "type": "string", "enum": ["MENU", "BACKBONE"] },
        "technique_family": {
          "type": "string",
          "enum": [
            "SAUCE",
            "PUREE",
            "GEL",
            "BAVAROIS",
            "PICKLE",
            "SALAD",
            "STOCK",
            "CRUMBLE",
            "CROUTON",
            "BEURRE_BLANC",
            "BRINE",
            "SYRUP",
            "JAM",
            "BREAD",
            "FAT",
            "CULTURED_DAIRY",
            "OIL",
            "OTHER"
          ]
        },
        "menu_cycle": { "type": ["string", "null"] },
        "plating_image_url": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "business_type": { "const": "MENU" } },
            "required": ["business_type"]
          },
          "then": {
            "properties": { "menu_cycle": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "if": {
            "properties": { "business_type": { "const": "BACKBONE" } },
            "required": ["business_type"]
          },
          "then": {
            "properties": { "menu_cycle": { "type": "null" } }
          }
        }
      ]
    },
    "production": {
      "type": "object",
      "additionalProperties": false,
      "required": ["yield", "net_yield_rate", "key_temperature_points"],
      "properties": {
        "yield": { "type": "string" },
        "net_yield_rate": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "key_temperature_points": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["point_id", "step", "temp_c", "hold_sec"],
            "properties": {
              "point_id": { "type": "string", "minLength": 1 },
              "step": { "type": "string" },
              "temp_c": { "type": "number" },
              "hold_sec": { "type": "number" },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "allergens": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ingredients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "quantity", "unit"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "quantity": { "type": "string", "minLength": 1 },
          "unit": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "step_no", "action", "time_sec"],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "step_no": { "type": "integer", "minimum": 1 },
          "action": { "type": "string", "minLength": 1 },
          "time_sec": { "type": "number", "minimum": 0 },
          "temp_c": { "type": "number" },
          "equipment": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "ccp": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "component_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_kind", "ref_name", "section"],
        "properties": {
          "component_kind": {
            "type": "string",
            "enum": ["RECIPE_REF", "REFERENCE_PREP", "RAW_ITEM", "FINISH_ITEM"]
          },
          "child_code": { "type": "string", "minLength": 1 },
          "ref_name": { "type": "string", "minLength": 1 },
          "component_role": { "type": "string" },
          "section": {
            "type": "string",
            "enum": ["PREP", "INTERMEDIATE", "ASSEMBLY", "FINISH", "PLATING"]
          },
          "quantity": { "type": "string" },
          "unit": { "type": "string" },
          "source_ref": { "type": "string" },
          "prep_note": { "type": "string" }
        }
      }
    }
  }
}
