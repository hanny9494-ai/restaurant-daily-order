# Qwen (DashScope)
# 至少配置下面任意一个变量名，推荐 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_APIKEY=your_dashscope_api_key_here
# QWEN_API_KEY=your_dashscope_api_key_here

# 可选：模型覆盖（默认 qwen3.5-plus / qwen3.5-vl-plus）
QWEN_TEXT_MODEL=qwen3.5-plus
QWEN_VISION_MODEL=qwen3.5-vl-plus

# 可选：bangwagong webhook
BANGWAGONG_WEBHOOK_URL=
BANGWAGONG_API_TOKEN=
